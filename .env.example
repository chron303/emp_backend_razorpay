# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Supabase / local / any pg-compatible host)
DATABASE_URL="postgresql://<user>:<password>@<host>:<port>/<database>"

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Secret key used to sign and verify JWTs — use a long random string in production
JWT_SECRET="replace_with_a_strong_random_secret"

# Token lifetime (e.g. 7d, 24h, 3600s)
JWT_EXPIRES_IN="7d"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=7002

# ─── Environment ──────────────────────────────────────────────────────────────
# development | production | test
NODE_ENV=development

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Frontend origin allowed to send cookies (used in app.js CORS config)
CLIENT_ORIGIN="http://localhost:3000"
